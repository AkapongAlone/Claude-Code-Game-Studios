{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git rev-parse*)",
      "Bash(ls *)",
      "Bash(dir *)",
      "Bash(python -m json.tool*)",
      "Bash(python -m pytest*)",
      "Bash(py -m pytest*)",
      "Bash(git mv *)",
      "Read(//Applications/**)",
      "Bash(mdfind \"kMDItemKind == 'Application'\")",
      "Bash(\"/Users/ek/Downloads/Godot.app/Contents/MacOS/Godot\" --version)",
      "Bash(\"/Users/ek/Downloads/Godot.app/Contents/MacOS/Godot\" --headless --path . --import)",
      "Bash(\"/Users/ek/Downloads/Godot.app/Contents/MacOS/Godot\" --headless --path . --script tests/headless_runner.gd)",
      "Bash(echo \"EXIT_CODE=$?\")",
      "Bash(echo \"---import done \\(exit $?\\)---\")",
      "Bash(\"/Users/ek/Downloads/Godot.app/Contents/MacOS/Godot\" --headless --path . --check-only --script src/ui/battle/battle_scene.gd)",
      "Bash(echo \"RUNNER_EXIT=$?\")",
      "Bash(\"/Users/ek/Downloads/Godot.app/Contents/MacOS/Godot\" --headless --path . --quit-after 120)",
      "Bash(echo \"GAME_BOOT_EXIT=$?\")",
      "WebSearch",
      "Bash(claude mcp *)",
      "Bash(npx claude *)",
      "Read(//Users/ek/.claude/**)",
      "Bash(/Users/ek/.nvm/versions/node/v24.11.1/bin/claude mcp *)",
      "Bash(npx replicate-mcp@latest --help)",
      "Bash(cat ~/.claude.json 2>/dev/null || echo \"FILE_NOT_FOUND\")",
      "Read(//Users/ek/**)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\('mcpServers exists:', 'mcpServers' in d\\); print\\(json.dumps\\(d.get\\('mcpServers', {}\\), indent=2\\)\\)\")",
      "Bash(python3 -c ' *)",
      "Bash(mv /tmp/claude_updated.json ~/.claude.json)",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); print\\(json.dumps\\(d.get\\('mcpServers', {}\\), indent=2\\)\\)\")",
      "mcp__replicate__create_models_predictions",
      "Bash(curl -s \"https://replicate.delivery/xezq/atcKWVB5IK78DBmlz8VjyzDmxI4tewSCOelOvfj0Ahl2vEeaB/tmp4yx7ph9l.png\" -o /Users/ek/Desktop/gaming/Claude-Code-Game-Studios/assets/art/characters/char_kaster_base_portrait.png)",
      "Bash(env)",
      "Bash(curl -s \"https://replicate.delivery/xezq/dhtPi13elHUxDiQzh7GEa9vkbOV3Etf3Q38wGDpVvBixeEeaB/tmpio1eqq_7.png\" -o /Users/ek/Desktop/gaming/Claude-Code-Game-Studios/assets/art/characters/char_kaster_base_portrait.png)",
      "mcp__replicate__search_models",
      "mcp__replicate__get_models",
      "mcp__replicate__list_models_versions",
      "Bash(python3 -c \"import json,sys; d=json.load\\(sys.stdin\\); [print\\(k,'->',v\\) for k,v in d.get\\('mcpServers',{}\\).items\\(\\)]\")",
      "Bash(python3 -m json.tool)",
      "mcp__replicate__create_files",
      "Bash(git remote *)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" \"https://raw.githubusercontent.com/AkapongAlone/Claude-Code-Game-Studios/main/design/art/Kaster.png\")",
      "mcp__replicate__create_predictions",
      "Bash(curl -s \"https://replicate.delivery/xezq/QkYKE3Q2NBJ1H1k837aVMXyVPfxIxlxzqnJVIFuuGulesUvWA/tmpp977mrh7.png\" -o /Users/ek/Desktop/gaming/Claude-Code-Game-Studios/assets/art/characters/char_kaster_base_portrait.png)",
      "Bash(curl -s \"https://replicate.delivery/xezq/DDBSkocQh6YdC5grkL26lk3eXxpAvL9Rim0JwXYJJ575XqXLA/tmp_7lols63.png\" -o /Users/ek/Desktop/gaming/Claude-Code-Game-Studios/assets/art/characters/char_kaster_base_portrait.png)",
      "Bash(node -e ' *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(sudo *)",
      "Bash(chmod 777*)",
      "Bash(*>.env*)",
      "Bash(cat *.env*)",
      "Bash(type *.env*)",
      "Read(**/.env*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/detect-gaps.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-commit.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-push.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-assets.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/validate-skill-change.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/notify.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-compact.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-compact.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-stop.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-agent.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/log-agent-stop.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash .claude/statusline.sh"
  }
}
